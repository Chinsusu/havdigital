---
import AnalyticsConsent from '../components/AnalyticsConsent.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://havdigital.com/#organization',
      name: 'HAV Digital Solutions',
      url: 'https://havdigital.com/',
      logo: {
        '@type': 'ImageObject',
        url: 'https://havdigital.com/assets/hav-logo.svg',
      },
      email: 'sales@havdigital.com',
    },
    {
      '@type': 'WebSite',
      '@id': 'https://havdigital.com/#website',
      url: 'https://havdigital.com/',
      name: 'HAV Digital Solutions',
      inLanguage: 'vi',
      publisher: { '@id': 'https://havdigital.com/#organization' },
    },
  ],
};
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <title>HAV Digital Solutions — Proxy toàn cầu &amp; VPS NVMe</title>
  <meta name="description" content="Proxy dân cư xoay, ISP tĩnh, datacenter riêng và VPS NVMe. Target theo quốc gia, thành phố hoặc nhà mạng; quản lý qua dashboard và API.">
  <meta name="theme-color" content="#0F1419">
  <meta name="color-scheme" content="light">
  <link rel="canonical" href="https://havdigital.com/">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="vi_VN">
  <meta property="og:site_name" content="HAV Digital Solutions">
  <meta property="og:title" content="Proxy phủ 190+ quốc gia. IP sạch, xoay theo ý bạn.">
  <meta property="og:description" content="Proxy dân cư, ISP, datacenter và VPS NVMe trên một hệ thống vận hành minh bạch.">
  <meta property="og:url" content="https://havdigital.com/">
  <meta property="og:image" content="https://havdigital.com/assets/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/assets/hav-icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&amp;family=Inter:wght@400;500;600&amp;family=Space+Grotesk:wght@500;700&amp;display=swap" rel="stylesheet">
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  <style is:global>
    :root{
      --ink:#0F1419;--gray-600:#5B6470;--gray-300:#D7DBE0;--gray-100:#F5F6F8;
      --white:#FFFFFF;--uplink:#00C878;--uplink-dark:#00A263;--header-h:64px;
      --container:1120px;--section-y:88px;
    }
    *,*::before,*::after{box-sizing:border-box}
    html{scroll-behavior:smooth;scroll-padding-top:calc(var(--header-h) + 20px)}
    body{margin:0;color:var(--ink);background:var(--white);font-family:"Inter",system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;font-size:16px;line-height:1.6;text-rendering:optimizeLegibility}
    body,button,a{-webkit-font-smoothing:antialiased}
    img,svg{display:block;max-width:100%}
    a{color:inherit;text-decoration:none}
    button,input,textarea,select{font:inherit}
    ::selection{background:var(--uplink);color:var(--ink)}
    .skip-link{position:fixed;left:16px;top:-80px;z-index:1000;background:var(--ink);color:var(--white);padding:10px 14px;border-radius:6px;transition:top .15s}
    .skip-link:focus{top:16px}
    .container{width:min(100% - 48px,var(--container));margin-inline:auto}
    .section{padding-block:var(--section-y)}
    .section--muted{background:var(--gray-100);border-block:1px solid var(--gray-300)}
    .eyebrow{margin:0 0 12px;color:var(--gray-600);font-size:12px;font-weight:600;letter-spacing:.14em;text-transform:uppercase}
    h1,h2,h3,p{margin-top:0}
    h1,h2,h3{font-family:"Space Grotesk","Inter",sans-serif;line-height:1.08;letter-spacing:-.025em}
    h1{font-size:clamp(36px,5vw,56px);margin-bottom:22px}
    h2{font-size:clamp(30px,4vw,40px);margin-bottom:16px}
    h3{font-size:22px;margin-bottom:12px}
    .section-head{max-width:720px;margin-bottom:42px}
    .section-head--center{margin-inline:auto;text-align:center}
    .section-sub{margin-bottom:0;color:var(--gray-600);font-size:16px}
    .mono,.metric,.price,.key,.coverage-count,.status-copy,.vps-table td:not(:last-child){font-family:"IBM Plex Mono",ui-monospace,SFMono-Regular,Consolas,monospace}
    .accent{color:var(--uplink-dark)}
    .btn{min-height:46px;display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:11px 18px;border:1px solid transparent;border-radius:6px;font-weight:600;line-height:1.1;transition:background-color .15s,color .15s,border-color .15s;cursor:pointer}
    .btn:focus-visible,a:focus-visible{outline:3px solid color-mix(in srgb,var(--uplink) 65%,white);outline-offset:3px}
    .btn--primary{background:var(--uplink);color:var(--ink)}
    .btn--primary:hover{background:var(--uplink-dark);color:var(--white)}
    .btn--ghost{border-color:var(--ink);background:transparent;color:var(--ink)}
    .btn--ghost:hover{background:var(--ink);color:var(--white)}
    .btn--full{width:100%}
    .site-header{height:var(--header-h);position:sticky;top:0;z-index:100;border-bottom:1px solid var(--gray-300);background:rgba(255,255,255,.94);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
    .header-inner{height:100%;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:24px}
    .brand{justify-self:start;display:flex;align-items:center;gap:9px;min-width:max-content}
    .brand svg{width:34px;height:34px;fill:var(--ink)}
    .brand .logo-node{fill:var(--uplink)}
    .brand-word{font-family:"Space Grotesk",sans-serif;font-size:24px;font-weight:700;letter-spacing:.04em}
    .main-nav{display:flex;align-items:center;gap:34px;font-size:14px}
    .main-nav a{position:relative;color:var(--gray-600)}
    .main-nav a::after{content:"";position:absolute;left:0;right:100%;bottom:-8px;height:2px;background:var(--uplink);transition:right .15s}
    .main-nav a:hover{color:var(--ink)}
    .main-nav a:hover::after{right:0}
    .header-cta{justify-self:end;min-height:40px;padding:9px 15px;font-size:14px}
    .hero{padding-top:72px;padding-bottom:0;text-align:center;overflow:hidden}
    .hero-copy{max-width:860px;margin-inline:auto}
    .hero-sub{max-width:58ch;margin:0 auto 28px;color:var(--gray-600);font-size:18px}
    .hero-actions{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
    .map-wrap{max-width:1000px;margin:32px auto 0;position:relative}
    .world-map{width:100%;height:auto;overflow:visible}
    .land-dot{fill:#C6CCD4}
    .map-core{fill:var(--uplink)}
    .map-core-dot{fill:var(--white)}
    .map-ring{fill:none;stroke:var(--uplink);stroke-width:2;transform-box:fill-box;transform-origin:center;animation:map-ripple 2.6s ease-out infinite}
    .map-ring--late{opacity:.7}
    .map-label{font-family:"IBM Plex Mono",monospace;font-size:12px;font-weight:500;fill:var(--ink);paint-order:stroke;stroke:var(--white);stroke-width:4px;stroke-linejoin:round}
    @keyframes map-ripple{0%{transform:scale(1);opacity:.9}80%,100%{transform:scale(3.2);opacity:0}}
    .stats-strip{position:relative;z-index:3;max-width:820px;margin:-28px auto 0;display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--gray-300);border-radius:8px;background:var(--white);overflow:hidden}
    .stat{padding:20px 14px}
    .stat+.stat{border-left:1px solid var(--gray-300)}
    .metric{display:block;margin-bottom:2px;font-size:26px;font-weight:500;line-height:1.1}
    .stat-label{display:block;color:var(--gray-600);font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase}
    .stats-note{max-width:820px;margin:10px auto 0;color:var(--gray-600);font-size:12px;line-height:1.5;text-align:left}
    .proxy-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
    .proxy-card{min-height:100%;display:flex;flex-direction:column;padding:30px 27px;border:1px solid var(--gray-300);border-radius:8px;background:var(--white);transition:border-color .15s}
    .proxy-card:hover{border-color:var(--uplink)}
    .key{margin-bottom:8px;color:var(--uplink-dark);font-size:12px;font-weight:500}
    .card-desc{margin-bottom:24px;color:var(--gray-600);font-size:14px}
    .feature-list{margin:0;padding:0;list-style:none;border-block:1px solid var(--gray-300)}
    .feature-list li{position:relative;padding:11px 0 11px 18px;font-size:14px}
    .feature-list li+li{border-top:1px solid var(--gray-300)}
    .feature-list li::before{content:"";position:absolute;left:0;top:19px;width:6px;height:6px;border-radius:50%;background:var(--uplink)}
    .price-wrap{margin-top:auto;padding-top:26px;margin-bottom:14px}
    .price{font-size:22px;font-weight:500;letter-spacing:-.04em}
    .price-note{display:block;color:var(--gray-600);font-size:12px}
    .cap-layout{display:grid;grid-template-columns:280px 1fr;gap:56px;align-items:start}
    .cap-layout .section-head{margin:0}
    .cap-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;border:1px solid var(--gray-300);border-radius:8px;overflow:hidden;background:var(--gray-300)}
    .cap-item{min-height:158px;padding:22px 18px;background:var(--white)}
    .cap-item .key{display:block;margin-bottom:9px;font-size:12px}
    .cap-item h3{font-family:"Inter",sans-serif;font-size:15.5px;letter-spacing:0;line-height:1.3;margin-bottom:8px}
    .cap-item p{margin:0;color:var(--gray-600);font-size:13.5px;line-height:1.55}
    .coverage-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:28px}
    .coverage-item{padding-top:19px;border-top:2px solid var(--ink)}
    .coverage-item h3{font-family:"Inter",sans-serif;font-size:16px;letter-spacing:0;margin-bottom:8px}
    .coverage-count{display:block;margin-bottom:12px;color:var(--uplink-dark);font-size:15px;font-weight:500}
    .coverage-item p{margin:0;color:var(--gray-600);font-size:14px}
    .vps-layout{display:grid;grid-template-columns:1fr 1.42fr;gap:54px;align-items:center}
    .vps-copy h2{font-size:34px}
    .vps-pitch{color:var(--gray-600)}
    .check-list{padding:0;margin:24px 0 0;list-style:none}
    .check-list li{position:relative;padding:8px 0 8px 20px}
    .check-list li::before{content:"";position:absolute;left:0;top:17px;width:7px;height:7px;border-radius:50%;background:var(--uplink)}
    .table-wrap{border:1px solid var(--gray-300);border-radius:8px;overflow:hidden;background:var(--white)}
    .vps-table{width:100%;border-collapse:collapse;font-size:13px}
    .vps-table th{padding:13px 12px;text-align:left;color:var(--gray-600);background:var(--white);font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase}
    .vps-table td{padding:17px 12px;border-top:1px solid var(--gray-300);white-space:nowrap}
    .vps-table td:last-child{text-align:right}
    .vps-table .btn{min-height:36px;padding:8px 11px;font-size:12px}
    .cta-section{padding-block:68px}
    .cta-box{display:flex;align-items:center;justify-content:space-between;gap:32px;padding:50px 54px;border-radius:8px;background:var(--ink);color:var(--white)}
    .cta-box h2{font-size:32px;margin-bottom:8px}
    .cta-box p{margin:0;color:#9AA4B2}
    .cta-box .btn{flex:0 0 auto}
    .site-footer{border-top:1px solid var(--gray-300);padding-block:28px;color:var(--gray-600);font-size:13px}
    .footer-inner{display:flex;align-items:center;justify-content:space-between;gap:24px}
    .footer-left,.footer-links{display:flex;align-items:center;gap:18px;flex-wrap:wrap}
    .status{display:inline-flex;align-items:center;gap:8px}
    .status-dot{width:8px;height:8px;border-radius:50%;background:var(--gray-600)}
    .status-copy{font-size:12px}
    .footer-links a:hover,.footer-links button:hover{color:var(--ink)}
    .footer-links button{padding:0;border:0;background:transparent;color:inherit;font:inherit;text-decoration:underline;cursor:pointer}
    @media (max-width:1000px){
      .cap-layout{grid-template-columns:1fr;gap:30px}
      .cap-grid{grid-template-columns:repeat(2,1fr)}
    }
    @media (max-width:900px){
      :root{--section-y:64px}
      .header-inner{grid-template-columns:1fr auto}
      .main-nav{display:none}
      .proxy-grid{grid-template-columns:1fr}
      .coverage-grid{grid-template-columns:repeat(2,1fr)}
      .vps-layout{grid-template-columns:1fr}
      .stats-strip{grid-template-columns:repeat(2,1fr);max-width:620px}
      .stat:nth-child(3){border-left:0;border-top:1px solid var(--gray-300)}
      .stat:nth-child(4){border-top:1px solid var(--gray-300)}
      .cta-box{padding:42px;align-items:flex-start;flex-direction:column}
      .footer-inner{align-items:flex-start;flex-direction:column}
    }
    @media (max-width:620px){
      .container{width:min(100% - 32px,var(--container))}
      .hero{padding-top:52px}
      .hero-sub{font-size:16px}
      .map-wrap{margin-top:22px}
      .land-dot{r:2.65px}
      .map-label{font-size:14px}
      .stats-strip{margin-top:-10px}
      .cap-grid,.coverage-grid{grid-template-columns:1fr}
      .cap-item{min-height:auto}
      .cta-box{padding:36px 26px}
      .cta-box .btn{width:100%}
      .vps-table thead{display:none}
      .vps-table,.vps-table tbody,.vps-table tr,.vps-table td{display:block;width:100%}
      .vps-table tr{padding:14px 16px;border-top:1px solid var(--gray-300)}
      .vps-table tr:first-child{border-top:0}
      .vps-table td{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:7px 0;border:0;white-space:normal;text-align:right}
      .vps-table td::before{content:attr(data-label);color:var(--gray-600);font-family:"Inter",sans-serif;font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;text-align:left}
      .vps-table td:last-child{padding-top:12px}
      .vps-table td:last-child::before{content:""}
      .vps-table td:last-child .btn{width:100%}
    }
    @media (max-width:520px){
      .brand-word{font-size:22px}
      .header-cta{font-size:13px;padding-inline:12px}
      .metric{font-size:20px}
      .stat{padding:17px 8px}
      .hero-actions .btn{width:100%}
      .proxy-card{padding:26px 22px}
    }
    @media (prefers-reduced-motion:reduce){
      html{scroll-behavior:auto}
      *,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.01ms!important}
      .map-ring,.status-dot{animation:none!important}
    }
  </style>
</head>
