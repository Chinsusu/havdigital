---
interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  robots?: string;
}

const { title, description, canonicalPath, robots } = Astro.props;
const canonical = canonicalPath && Astro.site
  ? new URL(canonicalPath, Astro.site).toString()
  : undefined;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
{robots && <meta name="robots" content={robots} />}
<title>{title}</title>
{description && <meta name="description" content={description} />}
{canonical && <link rel="canonical" href={canonical} />}
<meta name="theme-color" content="#0F1419" />
<meta name="color-scheme" content="light" />
<meta property="og:type" content="website" />
<meta property="og:locale" content="vi_VN" />
<meta property="og:site_name" content="HAV Digital Solutions" />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
{canonical && <meta property="og:url" content={canonical} />}
<meta property="og:image" content="https://havdigital.com/assets/og-image.png" />
<meta name="twitter:card" content="summary_large_image" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/assets/hav-icon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;700&display=swap"
  rel="stylesheet"
/>
